{
  "_metadata": {
    "major_version": 1,
    "minor_version": 1
  },
  "display_information": {
    "name": "File Watcher",
    "description": "Watches local folders and uploads matching files to Slack."
  },
  "features": {
    "bot_user": {
      "display_name": "File Watcher",
      "always_online": false
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "files:write",
        "chat:write",
        "im:write",
        "channels:read"
      ]
    }
  },
  "settings": {
    "socket_mode_enabled": false,
    "token_rotation_enabled": false
  }
}
