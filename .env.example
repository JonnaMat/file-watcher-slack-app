# --- Slack ---
# Bot User OAuth Token from api.slack.com/apps (xoxb-...)
SLACK_BOT_TOKEN=xoxb-your-token-here

# Your Slack user ID — the bot will send files to your App Home DM.
# Find it in Slack: click your profile photo → Profile → ⋯ menu → Copy member ID
SLACK_USER_ID=Uxxx

# --- Watcher ---
# Absolute path to the folder to watch (all subfolders are included)
WATCH_PATH=/home/user/watched

# Comma-separated glob patterns or file extensions to match.
# Examples: *.pdf,*.txt,*.md    report-*.csv    **/*.log    .docx
# Note: *.md are automatically converted to pdf
WATCH_PATTERNS=*.pdf,*.txt,*.md

# Debounce delay in milliseconds before uploading (default: 60000 = 60s)
# Use a smaller value like 5000 for testing
DEBOUNCE_MS=60000

# Optional message to post alongside the uploaded file
SLACK_MESSAGE="New file detected by File Watcher"
